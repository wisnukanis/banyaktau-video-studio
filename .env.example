# Server
NODE_ENV=development
LOG_LEVEL=info
PORT=3040
PUBLIC_BASE_URL=
AUTO_DASHBOARD_PIN=123456

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
STORY_MODEL=gpt-4.1-mini
IMAGE_MODEL=gpt-image-1-mini
IMAGE_SIZE=1024x1536
IMAGE_QUALITY=low
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=shimmer
OPENAI_TRANSCRIBE_MODEL=whisper-1

# Video clip provider (optional; kept separate so clips do not use the OpenAI key by accident)
VIDEO_PROVIDER=dinoiki-gemini
VIDEO_API_KEY=
VIDEO_BASE_URL=https://ai.dinoiki.com
# Use "gemini" for native Gemini/Veo long-running endpoints.
# Use "openai-videos" only if your provider exposes /v1/videos.
VIDEO_ENDPOINT_MODE=gemini
VIDEO_MODEL=veo-3.1-lite-generate-preview
VIDEO_ASPECT_RATIO=9:16
VIDEO_RESOLUTION=720p
VIDEO_SECONDS=4

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=pFZP5JQG7iQjIQuC4Bku

# Render
SPEECH_TEMPO=1.15
RENDER_CONCURRENCY_LIMIT=3

# Cost estimator defaults. Keep configurable because provider pricing can change.
STORY_INPUT_USD_PER_1M_TOKENS=0.40
STORY_OUTPUT_USD_PER_1M_TOKENS=1.60
OPENAI_TTS_USD_PER_1M_CHARS=15
ELEVENLABS_TTS_USD_PER_1K_CHARS=0.10
VIDEO_USD_PER_SECOND=0.03

# Gemini, reserved for future native Gemini integrations
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Facebook auto upload for the Dunialuas Page
FACEBOOK_UPLOAD_ENABLED=false
DUNIALUAS_FACEBOOK_PAGE_ID=
DUNIALUAS_FACEBOOK_PAGE_ACCESS_TOKEN=
DUNIALUAS_FACEBOOK_USER_ACCESS_TOKEN=
FACEBOOK_MEDIA_TYPE=reel
FACEBOOK_VIDEO_STATE=PUBLISHED
FACEBOOK_TITLE_PREFIX=
FACEBOOK_STRICT_PUBLISH=false
GRAPH_API_VERSION=v25.0

# Instagram Reels auto upload for the bhanyaktau account.
# Use the numeric Instagram Business/Creator user ID, not the @username.
# If INSTAGRAM_IG_USER_ID is empty, the app will try to read it from the Facebook Page's instagram_business_account.
INSTAGRAM_UPLOAD_ENABLED=false
BHANYAKTAU_INSTAGRAM_IG_USER_ID=
BHANYAKTAU_INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_SHARE_TO_FEED=true
INSTAGRAM_MAX_DURATION_SECONDS=90
INSTAGRAM_CONTAINER_POLL_SECONDS=6
INSTAGRAM_CONTAINER_MAX_ATTEMPTS=90

# Weekly remote cleanup keeps state/memory.json as duplicate-prevention memory.
BANYAKTAU_CLEANUP_DAYS=7
BANYAKTAU_CLEANUP_DELETE_ALL=false
BANYAKTAU_CLEANUP_DRY_RUN=false
BANYAKTAU_CLEANUP_SUBDIRS=videos,thumbnails,images,audio,clips
